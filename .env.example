# SwissFin Intelligence — environment configuration
# Copy this file to `.env` and adjust as needed. All values are optional;
# sensible defaults are baked into `swissfin.config.Settings`.

# --- Paths ---------------------------------------------------------------
# Root directory for all generated artefacts (audio, transcripts, outputs).
# Defaults to `<repo>/data`.
# SWISSFIN_DATA_DIR=./data

# Subdirectories — only override if you want a non-default layout.
# SWISSFIN_RAW_DIR=./data/raw
# SWISSFIN_TRANSCRIPTS_DIR=./data/transcripts
# SWISSFIN_OUTPUTS_DIR=./data/outputs

# HuggingFace model cache (defaults to `~/.cache/huggingface`).
# HF_HOME=~/.cache/huggingface

# --- Whisper -------------------------------------------------------------
# One of: tiny, base, small, medium, large-v3, turbo
SWISSFIN_WHISPER_MODEL=small

# Force a language code (de, en, fr, it). Leave blank to auto-detect.
# SWISSFIN_WHISPER_LANGUAGE=

# --- Sentiment ----------------------------------------------------------
SWISSFIN_SENTIMENT_MODEL=cardiffnlp/twitter-xlm-roberta-base-sentiment

# Inference batch size for the sentiment pipeline.
SWISSFIN_SENTIMENT_BATCH_SIZE=16

# --- Audio chunking -----------------------------------------------------
SWISSFIN_CHUNK_SECONDS=600
SWISSFIN_SILENCE_THRESH_DBFS=-40

# --- Logging ------------------------------------------------------------
# DEBUG / INFO / WARNING / ERROR
SWISSFIN_LOG_LEVEL=INFO
